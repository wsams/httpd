{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":semanticCommitTypeAll(fix)",
    ":semanticCommitScope(deps)"
  ],
  "labels": ["dependencies"],
  "timezone": "America/Los_Angeles",
  "automerge": true,
  "automergeType": "pr",
  "platformAutomerge": true,
  "automergeStrategy": "squash",
  "dependencyDashboard": true,
  "rangeStrategy": "pin",
  "packageRules": [
    {
      "description": "Automerge patch and minor updates",
      "matchUpdateTypes": ["patch", "minor", "digest", "pin", "pinDigest"],
      "automerge": true
    },
    {
      "description": "Require review for major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    },
    {
      "description": "Group npm semantic-release related packages",
      "matchManagers": ["npm"],
      "groupName": "semantic-release"
    }
  ]
}
